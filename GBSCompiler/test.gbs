int16 number = 25;
string value = "some text";
if(number <= 26){
	number = number + 1;
}
func main(){
	ret number;
}

call main();

`
INCLUDE "BreakoutTiles.asm"
	LoadTiles:
		ld de, Tiles 
		; Max tiles: 384
		ld hl, $9000 ; location in vram for tiles
		ld bc, TilesEnd - Tiles ; Count of tiles
	call MemCopy
	LoadTileMap:
		ld de, Tilemap 
		ld hl, $9800 ; tilemap offset
		ld bc, TilemapEnd - Tilemap 
	call MemCopy
`