

int16 number = 789;
int8 number2 = 10;

func main()
{
	number = 357;
	number2 = 50;
}


`
SCODI:
INCLUDE "BreakoutTiles.asm"
END_SCODI:

INITI:
	LoadTiles:
		ld de, Tiles 
		; Max tiles: 384
		ld hl, $9000 ; location in vram for tiles
		ld bc, TilesEnd - Tiles ; Count of tiles
	call MemCopy
	LoadTileMap:
		ld de, Tilemap 
		ld hl, $9800 ; tilemap offset
		ld bc, TilemapEnd - Tilemap 
	call MemCopy
END_INITI:
`